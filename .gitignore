# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
coverage
.nyc_output
.cache
*.local
.env
.env.*

# Local runtime state. SQLite WAL/SHM files can retain deleted rows, so keep the
# entire database set out of both new commits and ad-hoc smoke-test folders.
.smoke-data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite3

# Local credentials and package-manager auth. Commit only deliberately named
# example files containing placeholders. `/env` is a bare-named local secrets
# scratch file at the repo root; the .env patterns above do not cover it.
/env
.npmrc
*.pem
*.key
*.p12
*.pfx
*.jks
packages/backend/data/*.db
!*.example
packages/backend/data/recordings/*
!packages/backend/data/recordings/.gitkeep
packages/backend/data/recordings-raw/*
!packages/backend/data/recordings-raw/.gitkeep
packages/backend/data/outbound/*
!packages/backend/data/outbound/.gitkeep
packages/backend/data/greetings/*
!packages/backend/data/greetings/.gitkeep
packages/backend/data/callbacks/*
!packages/backend/data/callbacks/.gitkeep
packages/*/dist

# baresip SIP edge — never commit real registration credentials.
infra/baresip/accounts

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
