PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
COMFLOW_SEED_DEMO=true

# Secrets: keep these in your local .env, not the database.
COMFLOW_OPENAI_API_KEY=
COMFLOW_ANTHROPIC_API_KEY=
COMFLOW_ELEVENLABS_API_KEY=

# First-run defaults. Once you save settings in the app, the persisted values win.
COMFLOW_DEFAULT_LLM_PROVIDER=fake
COMFLOW_DEFAULT_LLM_MODEL=
COMFLOW_DEFAULT_STT_PROVIDER=fake
COMFLOW_DEFAULT_STT_MODEL=
COMFLOW_DEFAULT_TTS_PROVIDER=fake
COMFLOW_DEFAULT_TTS_MODEL=
COMFLOW_DEFAULT_TTS_VOICE=

# Example real defaults:
# COMFLOW_DEFAULT_LLM_PROVIDER=openai
# COMFLOW_DEFAULT_LLM_MODEL=gpt-4o-mini
# COMFLOW_DEFAULT_STT_PROVIDER=openai
# COMFLOW_DEFAULT_STT_MODEL=gpt-4o-mini-transcribe
# COMFLOW_DEFAULT_TTS_PROVIDER=openai
# COMFLOW_DEFAULT_TTS_MODEL=gpt-4o-mini-tts
# COMFLOW_DEFAULT_TTS_VOICE=alloy
