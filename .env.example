PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
COMFLOW_SEED_DEMO=true

# Where recordings, greetings, outbound + prompt audio and the SQLite DB live.
# Set to a shared volume path when running alongside the baresip SIP edge so
# both resolve audio paths identically (docker-compose sets this to /data).
# COMFLOW_DATA_DIR=/data

# Secrets: keep these in your local .env, not the database.
COMFLOW_OPENAI_API_KEY=
COMFLOW_ANTHROPIC_API_KEY=
COMFLOW_ELEVENLABS_API_KEY=

# First-run engine defaults. Once you save settings in the app, the persisted
# values win.
COMFLOW_DEFAULT_LLM_PROVIDER=fake
COMFLOW_DEFAULT_LLM_MODEL=
COMFLOW_DEFAULT_STT_PROVIDER=fake
COMFLOW_DEFAULT_STT_MODEL=
COMFLOW_DEFAULT_TTS_PROVIDER=fake
COMFLOW_DEFAULT_TTS_MODEL=
COMFLOW_DEFAULT_TTS_VOICE=

# Example real defaults:
# COMFLOW_DEFAULT_LLM_PROVIDER=openai
# COMFLOW_DEFAULT_LLM_MODEL=gpt-4o-mini
# COMFLOW_DEFAULT_STT_PROVIDER=openai
# COMFLOW_DEFAULT_STT_MODEL=gpt-4o-mini-transcribe
# COMFLOW_DEFAULT_TTS_PROVIDER=openai
# COMFLOW_DEFAULT_TTS_MODEL=gpt-4o-mini-tts
# COMFLOW_DEFAULT_TTS_VOICE=alloy

# --- Telephony (SIP edge) ---
# 'fake' = webhook-only (dev/tests). 'baresip' = real SIP UA edge.
COMFLOW_TELEPHONY=fake
BARESIP_CTRL_HOST=127.0.0.1
BARESIP_CTRL_PORT=4444
# WAV played to inbound callers before recording (overrides the mailbox greeting
# prompt). Path must be reachable by baresip (shared /data volume).
# COMFLOW_GREETING_PATH=/data/greetings/greeting.wav
# Outbound dialing (scheduled-call feature):
# COMFLOW_SIP_OUTBOUND_DOMAIN=pbx.example.com
COMFLOW_OUTBOUND_ANSWER_TIMEOUT_SEC=45
COMFLOW_OUTBOUND_CAPTURE_WINDOW_SEC=20
COMFLOW_SCHEDULER_INTERVAL_SEC=15

# --- AnchorDesk sync (reviewed voicemails -> tickets) ---
ANCHORDESK_SYNC_ENABLED=false
ANCHORDESK_BASE_URL=
ANCHORDESK_API_TOKEN=

# --- Auth (local accounts; SSO is on the roadmap) ---
# Open by default (no login required) so dev/tests stay frictionless.
COMFLOW_AUTH_REQUIRED=false
COMFLOW_AUTH_SESSION_SECRET=change-me-in-production
COMFLOW_AUTH_SESSION_TTL_HOURS=720
# Bootstrap admin created on first boot when both are set:
COMFLOW_BOOTSTRAP_ADMIN_EMAIL=
COMFLOW_BOOTSTRAP_ADMIN_PASSWORD=
